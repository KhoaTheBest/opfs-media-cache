{
  "name": "@btg-pencil-ai/browser-asset-caching",
  "packageManager": "yarn@4.4.0",
  "version": "0.0.3",
  "type": "module",
  "module": "./dist/index.esm.js",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.esm.js",
      "require": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "analyze": "vite build --mode analyze",
    "dev": "vite --config vite.demo-config.ts",
    "lint": "eslint . --ext .ts",
    "release": "yarn version --immediate patch && tsc && vite build && npm publish --non-interactive",
    "build": "vite build && tsc -p tsconfig.build.json",
    "build:watch": "tsc -p tsconfig.build.json && vite build --watch --emptyOutDir false",
    "build:demo": "vite build --config vite.demo-config.ts",
    "prepublishOnly": "yarn build",
    "preview": "vite preview"
  },
  "files": [
    "dist"
  ],
  "devDependencies": {
    "@types/node": "^22.13.10",
    "idb": "^8.0.0",
    "typescript": "^5.7.2",
    "vite": "^6.0.14",
    "vitest": "^2.1.9"
  },
  "dependencies": {
    "comlink": "^4.4.2",
    "opfs-tools": "^0.7.0"
  }
}
