{
  "name": "browser-asset-caching",
  "version": "0.0.1",
  "type": "module",
  "module": "dist/@pencil-asset-cache.js",
  "main": "dist/@pencil-asset-cache.umd.cjs",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/@pencil-asset-cache.js",
      "require": "./dist/@pencil-asset-cache.umd.cjs"
    }
  },
  "private": true,
  "scripts": {
    "dev": "vite --config vite.demo-config.ts",
    "lint": "eslint . --ext .ts",
    "build": "vite build && tsc -p tsconfig.build.json",
    "build:watch": "tsc -p tsconfig.build.json && vite build --watch --emptyOutDir false",
    "build:demo": "vite build --config vite.demo-config.ts",
    "prepublishOnly": "yarn build",
    "preview": "vite preview"
  },
  "files": [
    "dist"
  ],
  "devDependencies": {
    "idb": "^8.0.0",
    "typescript": "^5.7.2",
    "vite": "^6.0.3",
    "vitest": "^2.1.8"
  },
  "packageManager": "yarn@1.22.22+sha512.a6b2f7906b721bba3d67d4aff083df04dad64c399707841b7acf00f6b133b7ac24255f2652fa22ae3534329dc6180534e98d17432037ff6fd140556e2bb3137e"
}
